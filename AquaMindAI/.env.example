# ============================================================================
# AquaMind AI — Variables de entorno (ejemplo)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` y completa los valores según tu entorno.
# El BACKEND es quien lee estas variables (con dotenv). El frontend usa su
# propio .env (frontend/.env, ver más abajo).
#   Windows:      copy .env.example .env
#   macOS/Linux:  cp .env.example .env
# ============================================================================

# Entorno de ejecución del backend. En "production" se silencian los logs de
# cada request. Usa "development" para la demo.
NODE_ENV=development

# Puerto HTTP del backend (API REST + Socket.IO). El simulador y el frontend
# apuntan a este puerto por defecto.
PORT=4000

# ----------------------------------------------------------------------------
# Base de datos PostgreSQL (TODAS son REQUERIDAS: sin ellas el backend no arranca)
# ----------------------------------------------------------------------------
# Host donde corre PostgreSQL.
DB_HOST=localhost
# Puerto de PostgreSQL (por defecto 5432).
DB_PORT=5432
# Nombre de la base de datos (créala antes: CREATE DATABASE aquamind;).
DB_NAME=aquamind
# Usuario de PostgreSQL.
DB_USER=postgres
# Contraseña del usuario. CÁMBIALA por la tuya (no subas tu .env real al repo).
DB_PASSWORD=tu_password

# ----------------------------------------------------------------------------
# Servicios relacionados
# ----------------------------------------------------------------------------
# URL del servicio de IA (Flask). El backend le envía las lecturas a /analyze.
# Si la IA no responde, el backend usa un fallback y sigue funcionando.
AI_SERVICE_URL=http://localhost:5000

# Origen permitido para CORS y Socket.IO. Debe coincidir con la URL real del
# frontend (Vite por defecto usa el 5173).
FRONTEND_URL=http://localhost:5173

# ============================================================================
# FRONTEND (archivo aparte: frontend/.env — ver frontend/.env.example)
# ----------------------------------------------------------------------------
# VITE_API_URL apunta al backend; se usa para REST y Socket.IO.
#   VITE_API_URL=http://localhost:4000
# ============================================================================
